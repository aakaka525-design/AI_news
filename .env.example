# ====================================
# AI News Monitor Configuration
# ====================================

# ---- 数据源 ----
# Tushare 数据接口 Token（股票数据获取必需）
TUSHARE_TOKEN=your_tushare_token

# ---- 数据库配置 ----
# 默认 SQLite（本地开发），Docker 模式使用 PostgreSQL
DATABASE_URL=sqlite:///data/stocks.db
NEWS_DATABASE_URL=sqlite:///data/news.db
# PostgreSQL (docker-compose 模式下自动覆盖，无需手动设置)
# DATABASE_URL=postgresql://ainews:your_password@localhost:5432/ainews
# NEWS_DATABASE_URL=postgresql://ainews:your_password@localhost:5432/ainews

# 连接池配置（PostgreSQL，可选）
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# ---- Docker PostgreSQL ----
# [REQUIRED for Docker] 请改成强密码
POSTGRES_PASSWORD=change_me_ainews_db_password
# [REQUIRED for Docker] NocoDB 元数据库密码
NOCODB_META_PASSWORD=change_me_nocodb_meta_password

# ---- API 服务配置 ----
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://frontend:3000
ENV=dev

# ---- API 鉴权配置（生产建议开启）----
DASHBOARD_API_KEY=
API_KEY_REQUIRED=false
WEBHOOK_SECRET=
SCHEDULER_REQUIRED=false

# ---- AI 分析配置（可选）----
AI_ANALYSIS_ENABLED=false
# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
# OpenAI/DeepSeek 兼容接口（可选）
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# ---- 前端配置 ----
NEXT_PUBLIC_API_URL=/api/proxy
# BFF 代理到后端服务（前端容器内）
DASHBOARD_INTERNAL_URL=http://dashboard:8000

# ---- TrendRadar 爬虫配置（Docker 模式）----
ENABLE_CRAWLER=true
ENABLE_NOTIFICATION=true
REPORT_MODE=incremental
CRON_SCHEDULE=*/30 * * * *

# ---- Telegram 推送（可选）----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Polymarket 预测市场（可选）----
POLYMARKET_ENABLED=true
POLYMARKET_FETCH_INTERVAL=5
POLYMARKET_VOLATILITY_THRESHOLD=0.10

# ---- 调度器配置 ----
SCHEDULER_TIMEZONE=Asia/Shanghai

# ---- RSSHub（可选）----
RSSHUB_URL=http://localhost:1200
RSSHUB_ACCESS_KEY=

# ---- 代理配置（可选）----
PROXY_URI=
# 代理服务 API 鉴权（可选）
# PROXY_API_KEY=
# PROXY_API_PWD=

# ---- 日志 ----
LOG_LEVEL=INFO
