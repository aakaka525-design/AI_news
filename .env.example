# ====================================
# AI News Monitor Configuration
# ====================================

# 数据源 (Tinyshare)
TUSHARE_TOKEN=your_tinyshare_token

# 数据库配置 (默认 SQLite, Docker 模式使用 PostgreSQL)
DATABASE_URL=sqlite:///data/stocks.db
NEWS_DATABASE_URL=sqlite:///data/news.db
# PostgreSQL (docker-compose)
# DATABASE_URL=postgresql://ainews:ainews_dev@localhost:5432/ainews
# NEWS_DATABASE_URL=postgresql://ainews:ainews_dev@localhost:5432/ainews

# API 服务配置
API_HOST=0.0.0.0
API_PORT=8000

# API 鉴权配置（生产建议开启）
DASHBOARD_API_KEY=
API_KEY_REQUIRED=false
WEBHOOK_SECRET=

# AI 分析配置 (可选)
AI_ANALYSIS_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# 前端配置
NEXT_PUBLIC_API_URL=http://localhost:8000
# 仅当 API_KEY_REQUIRED=true 且需浏览器直连后端时设置
NEXT_PUBLIC_DASHBOARD_API_KEY=

# TrendRadar 爬虫配置 (Docker 模式)
ENABLE_CRAWLER=true
ENABLE_NOTIFICATION=true
REPORT_MODE=incremental
CRON_SCHEDULE=*/30 * * * *

# Telegram 推送 (可选)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Polymarket 预测市场 (可选)
POLYMARKET_ENABLED=true
POLYMARKET_FETCH_INTERVAL=5
POLYMARKET_VOLATILITY_THRESHOLD=0.10

# 日志级别
LOG_LEVEL=INFO
