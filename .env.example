# Tushare 配置
TUSHARE_TOKEN=your_token_here
TUSHARE_API_URL=https://jiaoch.site

# 数据库配置 (default: SQLite, for PostgreSQL uncomment below)
DATABASE_URL=sqlite:///data/stocks.db
NEWS_DATABASE_URL=sqlite:///data/news.db
# PostgreSQL (local development via docker-compose)
# DATABASE_URL=postgresql://ainews:ainews_dev@localhost:5432/ainews
# NEWS_DATABASE_URL=postgresql://ainews:ainews_dev@localhost:5432/ainews

# API 服务配置
API_HOST=0.0.0.0
API_PORT=8000

# LLM 配置 (可选)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# 日志级别
LOG_LEVEL=INFO
